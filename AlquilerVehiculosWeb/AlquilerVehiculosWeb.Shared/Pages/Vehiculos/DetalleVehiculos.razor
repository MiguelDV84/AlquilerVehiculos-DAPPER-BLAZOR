@page "/vehiculo/{Matricula}"
@rendermode InteractiveServer
@using WebApiNet.Shared.DTOs.Common
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.Enums
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation

@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else if (vehiculo == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-secondary" role="status"></div>
        <p>Cargando detalles del vehículo @Matricula...</p>
    </div>
}
else
{
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-secondary">Ficha de Vehículo</h2>
            <button class="btn btn-outline-primary" @onclick="@Volver">
                <i class="bi bi-arrow-left"></i> Volver
            </button>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0">Detalles del Vehículo</h4>
            </div>
            <div class="card-body bg-gradient p-4">
                <div class="row">
                    <div class="col-6 border-end">
                        <div class="mb-3">
                            <label class="fw-bold">Matrícula:</label>
                            <span class="ms-2">@vehiculo.Matricula</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Tipo de Vehículo:</label>
                            <span class="ms-2">
                                @switch (vehiculo.TipoVehiculo)
                                {
                                    case (int)TipoVehiculo.Furgoneta:
                                        @:Furgoneta
                                        break;
                                    case (int)TipoVehiculo.Camion:
                                        @:Camión
                                        break;
                                    case (int)TipoVehiculo.Turismo:
                                        @:Turismo
                                        break;
                                    case (int)TipoVehiculo.Deportivo:
                                        @:Deportivo
                                        break;
                                    case (int)TipoVehiculo.Monovolumen:
                                        @:Monovolumen
                                        break;
                                    case (int)TipoVehiculo.Caravana:
                                        @:Caravana
                                        break;
                                    default:
                                        @:Desconocido
                                        break;
                                }
                            </span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Kilometraje:</label>
                            <span class="ms-2">@vehiculo.Kilometraje.ToString("N0") km</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Litros del Tanque:</label>
                            <span class="ms-2">@vehiculo.LitrosTanque L</span>
                        </div>
                    </div>

                    <div class="col-6 ps-md-4">
                        <div class="mb-3">
                            <label class="fw-bold">Marca:</label>
                            <span class="ms-2">@vehiculo.Marca</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Modelo:</label>
                            <span class="ms-2">@vehiculo.Modelo</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Precio:</label>
                            <span class="ms-2">@vehiculo.Precio.ToString("C")</span>
                        </div>
                        <div>
                            <label class="fw-bold">Estado:</label>
                            <span class="ms-2">
                                @switch (vehiculo.Estado)
                                {
                                    case (int)EstadoVehiculo.Disponible:
                                        <span class="badge bg-success">Disponible</span>
                                        break;
                                    case (int)EstadoVehiculo.Alquilado:
                                        <span class="badge bg-danger">Alquilado</span>
                                        break;
                                    case (int)EstadoVehiculo.EnMantenimiento:
                                        <span class="badge bg-warning text-dark">En Mantenimiento</span>
                                        break;
                                    case (int)EstadoVehiculo.Vendido:
                                        <span class="badge bg-secondary">Vendido</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">Desconocido</span>
                                        break;
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {

    // --- PARÁMETRO DE RUTA ---
    // Este valor viene directamente de la URL (ej: /vehiculo/1234BBB).
    // Blazor lo inyecta automáticamente gracias al atributo [Parameter].
    [Parameter]
    public string Matricula { get; set; } = string.Empty;

    // --- VARIABLES DE ESTADO ---
    // Guardará la información de un único vehículo después de consultar la API.
    private VehiculoResponse? vehiculo;

    // Control de acceso para evitar que usuarios sin login vean los datos.
    private bool isAuthorized = false;

    // --- CICLO DE VIDA: AL INICIAR EL COMPONENTE ---
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Solo ejecutamos la lógica de seguridad y carga la primera vez que se renderiza.
        if (firstRender)
        {
            // 1. RECOGIDA DE CREDENCIALES: Buscamos el token JWT en el LocalStorage.
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            if (string.IsNullOrEmpty(token))
            {
                // SEGURIDAD: Si no hay llave (token), redirigimos al Login.
                Navigation.NavigateTo("/login");
            }
            else
            {
                // 2. CARGA DE DATOS: Si hay token, pedimos los detalles a la API.
                isAuthorized = true;
                await CargarDetalles(token);

                // Forzamos el repintado de la UI porque los datos han llegado de forma asíncrona.
                StateHasChanged(); 
            }
        }
    }

    // --- CONSUMO DE API (GET BY ID/MATRICULA) ---
    private async Task CargarDetalles(string token)
    {
        try
        {
            // 1. AUTORIZACIÓN: Añadimos el token al Header de la petición HTTP.
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            // 2. PETICIÓN ESPECÍFICA: Llamamos al endpoint que devuelve UN solo vehículo.
            // Usamos 'GetFromJsonAsync' para simplificar: pide el JSON y lo convierte a objeto en un solo paso.
            var response = await Http.GetFromJsonAsync<ApiResponse<VehiculoResponse>>($"api/vehiculos/{Matricula}");

            if (response != null && response.Success)
            {
                // 3. ASIGNACIÓN: Guardamos los datos recibidos en nuestra variable local 'vehiculo'.
                vehiculo = response.Data;
            }
        }
        catch (Exception ex)
        {
            // CONTROL DE ERRORES: Registramos en consola si la API falla o la matrícula no existe.
            Console.WriteLine($"Error al cargar detalles: {ex.Message}");
        }
    }

    // --- NAVEGACIÓN ---
    // Método sencillo para regresar a la lista principal sin recargar la página entera.
    private void Volver() => Navigation.NavigateTo("/catalogo");
}