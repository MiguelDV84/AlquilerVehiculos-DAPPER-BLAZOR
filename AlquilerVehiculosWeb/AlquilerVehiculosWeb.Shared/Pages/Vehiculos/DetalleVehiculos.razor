@page "/vehiculo/{Matricula}"
@rendermode InteractiveServer
@using WebApiNet.Application.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation


@if (vehiculo == null){
    <div class="text-center">        
        <div class="spinner-border text-primary" role="status"></div>
        <p>Cargando detalles del vehículo @Matricula...</p>
    </div>
}
else{
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-secondary">Ficha Vehiculo</h2>
            <button class="btn btn-outline-primary" @onclick="@Volver">
                <i class="bi bi-arrow-left"></i>Volver
            </button>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0">Detalles del Vehiculo</h4>
            </div>
            <div class="card-body bg-gradient p-4">
                <div class="row">
                    <div class="col-6 border-end">
                        <div class="mb-3">
                            <label class="fw-bold">Matricula:</label>
                            <span>@vehiculo.Matricula</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Tipo de Vehiculo: </label>
                            @switch ((int)vehiculo.TipoVehiculo)
                            {
                                case 0:
                                    @(" Furgoneta")
                                    break;
                                case 1:
                                    @(" Camión")
                                    break;
                                case 2:
                                    @(" Turismo")
                                    break;
                                case 3:
                                    @(" Deportivo")
                                    break;
                                case 4:
                                    @(" Monovolumen")
                                    break;
                                case 5:
                                    @(" Caravana")
                                    break;
                                default:
                                    @(" Desconocido")
                                    break;
                            }
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Kilometraje: </label>
                            <span>@vehiculo.Kilometraje.ToString("N0") km</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Litros del Tanque:</label>
                            <span>@vehiculo.LitrosTanque</span>
                        </div>
                    </div>
                
                    <div class="col-6 ps-md-4">
                        <div class="mb-3">
                            <label class="fw-bold">Marca: </label>
                            <span>@vehiculo.Marca</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Modelo: </label>
                            <span>@vehiculo.Modelo</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Precio: </label>
                            <span>@vehiculo.Precio.ToString("C")</span>
                        </div>
                        <div>
                            <label class="fw-bold">Estado:</label>
                            @switch ((int)vehiculo.Estado)
                            {
                                case 0:
                                <span class="badge bg-success"> Disponible</span>
                                break;

                                case 1:
                                <span class="badge bg-danger"> Alquilado</span>
                                break;

                                case 2:
                                <span class="badge bg-warning"> En Mantenimiento</span>
                                break;

                                case 3:
                                <span class="badge bg-secondary"> Vendido</span>
                                break;

                                default:
                                <span class="badge bg-light text-dark">Desconocido</span>
                                break;
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
}

@code {
    [Parameter]
    public String Matricula { get; set; }

    private Vehiculo? vehiculo;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<ApiResponse<Vehiculo>>($"api/vehiculos/{Matricula}");

            if (response != null && response.Success)
            {
                vehiculo = response.Data;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar detalles: {ex.Message}");
        }
    }

    private void Volver() => Navigation.NavigateTo("/catalogo");
}