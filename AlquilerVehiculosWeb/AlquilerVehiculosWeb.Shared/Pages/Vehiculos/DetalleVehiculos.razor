@page "/vehiculo/{Matricula}"
@rendermode InteractiveServer
@using WebApiNet.Shared.DTOs.Common
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.Enums
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Navigation

@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else if (vehiculo == null)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-secondary" role="status"></div>
        <p>Cargando detalles del vehículo @Matricula...</p>
    </div>
}
else
{
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-secondary">Ficha de Vehículo</h2>
            <button class="btn btn-outline-primary" @onclick="@Volver">
                <i class="bi bi-arrow-left"></i> Volver
            </button>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-dark text-white py-3">
                <h4 class="mb-0">Detalles del Vehículo</h4>
            </div>
            <div class="card-body bg-gradient p-4">
                <div class="row">
                    <div class="col-6 border-end">
                        <div class="mb-3">
                            <label class="fw-bold">Matrícula:</label>
                            <span class="ms-2">@vehiculo.Matricula</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Tipo de Vehículo:</label>
                            <span class="ms-2">
                                @switch (vehiculo.TipoVehiculo)
                                {
                                    case (int)TipoVehiculo.Furgoneta:
                                        @:Furgoneta
                                        break;
                                    case (int)TipoVehiculo.Camion:
                                        @:Camión
                                        break;
                                    case (int)TipoVehiculo.Turismo:
                                        @:Turismo
                                        break;
                                    case (int)TipoVehiculo.Deportivo:
                                        @:Deportivo
                                        break;
                                    case (int)TipoVehiculo.Monovolumen:
                                        @:Monovolumen
                                        break;
                                    case (int)TipoVehiculo.Caravana:
                                        @:Caravana
                                        break;
                                    default:
                                        @:Desconocido
                                        break;
                                }
                            </span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Kilometraje:</label>
                            <span class="ms-2">@vehiculo.Kilometraje.ToString("N0") km</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Litros del Tanque:</label>
                            <span class="ms-2">@vehiculo.LitrosTanque L</span>
                        </div>
                    </div>

                    <div class="col-6 ps-md-4">
                        <div class="mb-3">
                            <label class="fw-bold">Marca:</label>
                            <span class="ms-2">@vehiculo.Marca</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Modelo:</label>
                            <span class="ms-2">@vehiculo.Modelo</span>
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Precio:</label>
                            <span class="ms-2">@vehiculo.Precio.ToString("C")</span>
                        </div>
                        <div>
                            <label class="fw-bold">Estado:</label>
                            <span class="ms-2">
                                @switch (vehiculo.Estado)
                                {
                                    case (int)EstadoVehiculo.Disponible:
                                        <span class="badge bg-success">Disponible</span>
                                        break;
                                    case (int)EstadoVehiculo.Alquilado:
                                        <span class="badge bg-danger">Alquilado</span>
                                        break;
                                    case (int)EstadoVehiculo.EnMantenimiento:
                                        <span class="badge bg-warning text-dark">En Mantenimiento</span>
                                        break;
                                    case (int)EstadoVehiculo.Vendido:
                                        <span class="badge bg-secondary">Vendido</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">Desconocido</span>
                                        break;
                                }
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {


    [Parameter]
    public string Matricula { get; set; } = string.Empty;

    private VehiculoResponse? vehiculo;

    private bool isAuthorized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Buscamos el token en el navegador
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            if (string.IsNullOrEmpty(token))
            {
                // Si no hay token, fuera al login
                Navigation.NavigateTo("/login");
            }
            else
            {
                // Si hay token, autorizamos y cargamos los datos del vehículo
                isAuthorized = true;
                await CargarDetalles(token);
                StateHasChanged(); // Refrescamos para mostrar los datos
            }
        }
    }

    private async Task CargarDetalles(string token)
    {
        try
        {
            // Configuramos el token en la cabecera para la petición a la API
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.GetFromJsonAsync<ApiResponse<VehiculoResponse>>($"api/vehiculos/{Matricula}");

            if (response != null && response.Success)
            {
                vehiculo = response.Data;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar detalles: {ex.Message}");
        }
    }

    private void Volver() => Navigation.NavigateTo("/catalogo");
}