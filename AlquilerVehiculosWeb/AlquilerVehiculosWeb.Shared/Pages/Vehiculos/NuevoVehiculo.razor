@page "/nuevo-vehiculo"
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.DTOs.Common
@using WebApiNet.Shared.Enums
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else
{

    <div class="container mt-4">
        <h3 class="mb-4">Nuevo Vehículo</h3>

        <div class="card shadow-sm">
            <div class="card-body">
                <EditForm Model="@nuevoVehiculo" OnValidSubmit="GuardarVehiculo">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger" />

                    <div class="mb-3">
                        <label for="matricula" class="form-label">Matrícula:</label>
                        <InputText @bind-Value="nuevoVehiculo.Matricula" class="form-control" placeholder="Ej: 1234BBB" />
                        <small class="form-text text-muted">Formato: 4 números + 3 letras (ej: 1234BBB)</small>
                    </div>

                    <div class="mb-3">
                        <label for="tipovehiculo" class="form-label">Tipo de Vehículo:</label>
                        <InputSelect @bind-Value="nuevoVehiculo.TipoVehiculo" class="form-select">
                            <option value="">-- Seleccione un tipo --</option>
                            @foreach (var tipo in Enum.GetValues<TipoVehiculo>())
                            {
                                <option value="@tipo">@tipo</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label for="kilometraje" class="form-label">Kilometraje (km):</label>
                        <InputNumber @bind-Value="nuevoVehiculo.Kilometraje" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="marca" class="form-label">Marca:</label>
                        <InputText @bind-Value="nuevoVehiculo.Marca" class="form-control" placeholder="Ej: Toyota" />
                    </div>

                    <div class="mb-3">
                        <label for="modelo" class="form-label">Modelo:</label>
                        <InputText @bind-Value="nuevoVehiculo.Modelo" class="form-control" placeholder="Ej: Corolla" />
                    </div>

                    <div class="mb-3">
                        <label for="precio" class="form-label">Precio por día:</label>
                        <InputNumber @bind-Value="nuevoVehiculo.Precio" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="litrostanque" class="form-label">Litros del Tanque:</label>
                        <InputNumber @bind-Value="nuevoVehiculo.LitrosTanque" class="form-control" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    // Control de seguridad para proteger la ruta
    private bool isAuthorized = false;

    // --- MODELO DE SOLICITUD ---
    // Instanciamos un objeto vacío de tipo VehiculoRequest.
    // Este objeto recogerá todos los datos del formulario mediante bind-value.
    private VehiculoRequest nuevoVehiculo = new();

    // --- CICLO DE VIDA ---
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Verificamos si el usuario tiene el token para permitirle crear vehículos.
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            if (string.IsNullOrEmpty(token))
            {
                Navigation.NavigateTo("/login");
            }
            else
            {
                isAuthorized = true;
                StateHasChanged(); // Mostramos el formulario tras la validación
            }
        }
    }

    // --- ACCIÓN: GUARDAR (POST) ---
    private async Task GuardarVehiculo()
    {
        try
        {
            // 1. RECOGIDA DE TOKEN: Necesario para autorizar la creación en la API.
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            // 2. CONFIGURACIÓN DE CABECERAS:
            // Limpiamos cabeceras previas y añadimos el Bearer Token actual.
            Http.DefaultRequestHeaders.Authorization = null;
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            // 3. ENVÍO DE DATOS (HTTP POST):
            // Enviamos el objeto 'nuevoVehiculo' a la API.
            // El método PostAsJsonAsync se encarga de convertir nuestro objeto C# a formato JSON.
            var response = await Http.PostAsJsonAsync("api/vehiculos", nuevoVehiculo);

            if (response.IsSuccessStatusCode)
            {
                // ÉXITO: Feedback positivo al usuario y redirección al catálogo para ver el nuevo coche.
                await JS.InvokeVoidAsync("alert", "Vehículo creado exitosamente");
                Navigation.NavigateTo("/catalogo");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await JS.InvokeVoidAsync("alert", "Sesión no válida. Por favor, inicia sesión.");
                Navigation.NavigateTo("/login");
            }
            else
            {
                // ERROR DE VALIDACIÓN O BBDD: Leemos el mensaje de error que nos manda la API (compañero).
                var errorContent = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error al guardar: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error de conexión: {ex.Message}");
            await JS.InvokeVoidAsync("alert", "Error de conexión con el servidor.");
        }
    }

    // --- CANCELAR ---
    private async Task Cancelar()
    {
        // Validación de salida para no perder datos por un clic accidental.
        var confirmacion = await JS.InvokeAsync<bool>("confirm", "¿Deseas cancelar? Se perderán los datos introducidos.");

        if (confirmacion)
        {
            Navigation.NavigateTo("/catalogo");
        }
    }
}