@page "/nuevo-vehiculo"
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.DTOs.Common
@using WebApiNet.Shared.Enums
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else
{

    <div class="container mt-4">
        <h3 class="mb-4">Nuevo Vehículo</h3>

        <div class="card shadow-sm">
            <div class="card-body">
                <EditForm Model="@nuevoVehiculo" OnValidSubmit="GuardarVehiculo">
                    <DataAnnotationsValidator />

                    <ValidationSummary class="alert alert-danger" />

                    <div class="mb-3">
                        <label class="form-label">Matrícula:</label>
                        <div class="input-group">
                            <InputText @bind-Value="nuevoVehiculo.Matricula"
                                       @onblur="ValidarMatricula"
                                       class="@(string.IsNullOrEmpty(mensajeErrorMatricula) ? "form-control" : "form-control is-invalid")" />
                            @if (validandoMatricula)
                            {
                                <span class="input-group-text">
                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                </span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(mensajeErrorMatricula))
                        {
                            <div class="text-danger mt-1 small">@mensajeErrorMatricula</div>
                        }
                    </div>

                    <div class="mb-3">
                        <label for="tipovehiculo" class="form-label">Tipo de Vehículo:</label>
                        <InputSelect @bind-Value="nuevoVehiculo.TipoVehiculo" class="form-select">
                            <option value="">-- Seleccione un tipo --</option>
                            @foreach (var tipo in Enum.GetValues<TipoVehiculo>())
                            {
                                <option value="@tipo">@tipo</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label for="kilometraje" class="form-label">Kilometraje (km):</label>
                        <InputNumber @bind-Value="nuevoVehiculo.Kilometraje" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="marca" class="form-label">Marca:</label>
                        <InputText @bind-Value="nuevoVehiculo.Marca" class="form-control" placeholder="Ej: Toyota" />
                    </div>

                    <div class="mb-3">
                        <label for="modelo" class="form-label">Modelo:</label>
                        <InputText @bind-Value="nuevoVehiculo.Modelo" class="form-control" placeholder="Ej: Corolla" />
                    </div>

                    <div class="mb-3">
                        <label for="precio" class="form-label">Precio por día:</label>
                        <InputNumber @bind-Value="nuevoVehiculo.Precio" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label for="litrostanque" class="form-label">Litros del Tanque:</label>
                        <InputNumber @bind-Value="nuevoVehiculo.LitrosTanque" class="form-control" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}
