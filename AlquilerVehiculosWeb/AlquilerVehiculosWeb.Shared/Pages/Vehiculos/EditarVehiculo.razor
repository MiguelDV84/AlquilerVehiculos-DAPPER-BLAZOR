@page "/editar-vehiculo/{Matricula}"
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS



@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else if (modeloEdicion == null)
{
    <div class="d-flex align-items-center">
        <strong>Cargando datos del vehículo...</strong>
        <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
    </div>
}
else
{
    <h3>Editar Vehículo: @Matricula</h3>

    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="modeloEdicion" OnValidSubmit="editarVehiculo">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger" />
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Marca:</label>
                        <InputText @bind-Value="modeloEdicion.Marca" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Modelo:</label>
                        <InputText @bind-Value="modeloEdicion.Modelo" class="form-control" />
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Precio por día:</label>
                        <InputNumber @bind-Value="modeloEdicion.Precio" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Kilometraje (km):</label>
                        <InputNumber @bind-Value="modeloEdicion.Kilometraje" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Litros Tanque:</label>
                        <InputNumber @bind-Value="modeloEdicion.LitrosTanque" class="form-control" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Guardar cambios
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}
