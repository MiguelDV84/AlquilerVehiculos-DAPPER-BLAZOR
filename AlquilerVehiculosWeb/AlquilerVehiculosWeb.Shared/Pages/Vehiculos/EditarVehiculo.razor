@page "/editar-vehiculo/{Matricula}"
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS



@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else if (modeloEdicion == null)
{
    <div class="d-flex align-items-center">
        <strong>Cargando datos del vehículo...</strong>
        <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
    </div>
}
else
{
    <h3>Editar Vehículo: @Matricula</h3>

    <div class="card shadow-sm">
        <div class="card-body">
            <EditForm Model="modeloEdicion" OnValidSubmit="editarVehiculo">
                <DataAnnotationsValidator />
                <ValidationSummary class="alert alert-danger" />
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Marca:</label>
                        <InputText @bind-Value="modeloEdicion.Marca" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Modelo:</label>
                        <InputText @bind-Value="modeloEdicion.Modelo" class="form-control" />
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Precio por día:</label>
                        <InputNumber @bind-Value="modeloEdicion.Precio" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Kilometraje (km):</label>
                        <InputNumber @bind-Value="modeloEdicion.Kilometraje" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-bold">Litros Tanque:</label>
                        <InputNumber @bind-Value="modeloEdicion.LitrosTanque" class="form-control" />
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Guardar cambios
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}


@code {
    // --- PARÁMETRO DE RUTA ---
    // Recibimos la matrícula desde la URL para saber QUÉ coche estamos editando.
    [Parameter] public string Matricula { get; set; } = string.Empty;

    // Control de seguridad
    private Boolean isAuthorized = false;

    // --- MODELO DE FORMULARIO ---
    // Instanciamos el DTO de actualización.
    // Sus propiedades están vinculadas (bind) a los inputs del formulario.
    private VehiculoUpdateRequest modeloEdicion = new();

    // --- PASO 1: CARGAR DATOS ACTUALES (GET) ---
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Verificamos si el usuario tiene el token de sesión.
                var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

                if (string.IsNullOrEmpty(token))
                {
                    Navigation.NavigateTo("/login");
                    return;
                }

                // Preparamos la petición para traer los datos actuales del coche.
                var request = new HttpRequestMessage(HttpMethod.Get, $"api/vehiculos/{Matricula}");
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var response = await Http.SendAsync(request);

                if (response.IsSuccessStatusCode)
                {
                    var result = await response.Content.ReadFromJsonAsync<ApiResponse<VehiculoResponse>>();
                    if (result != null && result.Success)
                    {
                        // MAPEADO: Pasamos los datos de la base de datos al modelo del formulario.
                        // Esto permite que el usuario vea lo que ya había escrito antes de editar.
                        modeloEdicion.Modelo = result.Data.Modelo;
                        modeloEdicion.Marca = result.Data.Marca;
                        modeloEdicion.Precio = result.Data.Precio;
                        modeloEdicion.Kilometraje = result.Data.Kilometraje;
                        modeloEdicion.LitrosTanque = result.Data.LitrosTanque;

                        isAuthorized = true;
                        StateHasChanged(); // Repintamos la interfaz con los datos cargados.
                    }
                }
                else
                {
                    await JS.InvokeVoidAsync("alert", "No se pudieron cargar los datos.");
                    Navigation.NavigateTo("/catalogo");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al cargar: {ex.Message}");
            }
        }
    }

    // --- PASO 2: ENVIAR CAMBIOS A LA API (PUT) ---
    public async Task editarVehiculo()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            // Adjuntamos el token para que la API nos deje hacer cambios.
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            // PETICIÓN HTTP PUT: Enviamos el objeto 'modeloEdicion' serializado como JSON.
            // El PUT se usa para actualizaciones completas del recurso.
            var responseEditar = await Http.PutAsJsonAsync($"api/vehiculos/{Matricula}", modeloEdicion);

            if (responseEditar.IsSuccessStatusCode)
            {
                // Si la API responde OK, avisamos y volvemos al catálogo.
                await JS.InvokeVoidAsync("alert", "Vehículo actualizado correctamente");
                Navigation.NavigateTo("/catalogo");
            }
            else if (responseEditar.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await JS.InvokeVoidAsync("alert", "Sesión expirada.");
                Navigation.NavigateTo("/login");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Error al editar el vehículo.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Error de conexión.");
        }
    }

    // --- CANCELACIÓN ---
    private async Task Cancelar()
    {
        // Preguntamos al usuario antes de salir para que no pierda cambios por error.
        bool confirmado = await JS.InvokeAsync<bool>("confirm", "¿Estás seguro? Se perderán los cambios.");
        if (confirmado)
        {
            Navigation.NavigateTo("/catalogo");
        }
    }
}