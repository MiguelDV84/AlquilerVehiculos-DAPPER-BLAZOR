@page "/catalogo"
@rendermode InteractiveServer
@using AlquilerVehiculosWeb.Shared
@using WebApiNet.Shared.DTOs.Common
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.Enums
@using WebApiNet.Shared.Paged
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Gestión de Catálogo</PageTitle>

@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Verificando autorización...</p>
    </div>
}
else
{
    <div class="container py-4">
        @* CABECERA Y BUSCADOR *@
        <div class="bg-light p-4 rounded-4 shadow-sm mb-5 border">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h2 class="fw-bold mb-1">Catálogo de Vehículos</h2>
                    <p class="text-muted">Gestiona la flota y disponibilidad en tiempo real.</p>
                    <div class="input-group input-group-lg shadow-sm mt-3">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-primary"></i>
                        </span>
                        <input type="text"
                               class="form-control border-start-0 ps-0"
                               placeholder="Escribe marca o modelo (ej: Porsche)..."
                               @bind="textoBusqueda"
                               @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <button class="btn btn-success btn-lg shadow-sm" @onclick="IrANuevoVehiculo">
                        <i class="bi bi-plus-circle me-2"></i>Nuevo Vehículo
                    </button>
                </div>
            </div>
        </div>

        @if (listaDeVehiculo == null)
        {
            <div class="text-center my-5">
                <div class="spinner-grow text-primary" role="status"></div>
                <p class="mt-3 text-muted">Cargando flota desde la API...</p>
            </div>
        }
        else if (listaDeVehiculo.Count == 0)
        {
            <div class="alert alert-warning text-center rounded-3">
                <i class="bi bi-exclamation-triangle me-2"></i> No se encontraron vehículos en la base de datos.
            </div>
        }
        else
        {
            @* GRID DE TARJETAS *@
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                @if (VehiculoFiltrados != null && VehiculoFiltrados.Any())
                {
                    @foreach (var v in VehiculoFiltrados)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden vehicle-card">
                                @* ESPACIO PARA IMAGEN *@
                                <div class="bg-light d-flex align-items-center justify-content-center p-4" style="height: 160px;">
                                    <i class="bi bi-car-front text-secondary opacity-50" style="font-size: 4.5rem;"></i>
                                </div>

                                @* CONTENIDO *@
                                <div class="card-body p-3 d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <h6 class="fw-bold text-uppercase mb-0 text-truncate" style="max-width: 70%;">@v.Marca</h6>
                                        <span class="badge bg-dark font-monospace" style="font-size: 0.7rem;">@v.Matricula</span>
                                    </div>
                                    <h5 class="card-title text-muted mb-3" style="font-size: 0.95rem;">@v.Modelo</h5>

                                    <div class="mb-3">
                                        <span class="text-primary fw-bold fs-4">@v.Precio.ToString("C")</span>
                                        <span class="text-muted small">/ día</span>
                                    </div>

                                    <div class="mb-4">
                                        @switch ((int)v.Estado)
                                        {
                                            case 0:
                                                <span class="badge rounded-pill status-available">Disponible</span>
                                                break;
                                            case 1:
                                                <span class="badge rounded-pill status-rented">Alquilado</span>
                                                break;
                                            default:
                                                <span class="badge rounded-pill status-maintenance">No Disponible</span>
                                                break;
                                        }
                                    </div>

                                    @* ACCIONES *@
                                    <div class="d-flex gap-2 mt-auto">
                                        <button class="btn btn-outline-primary btn-sm flex-grow-1" @onclick="() => VerDetalles(v.Matricula)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-outline-warning btn-sm flex-grow-1" @onclick="() => EditarVehiculo(v.Matricula)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm flex-grow-1" @onclick="() => BorrarVehiculo(v.Matricula)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <i class="bi bi-search text-muted opacity-25" style="font-size: 4rem;"></i>
                        <p class="mt-3 text-muted">No hay resultados para "<strong>@textoBusqueda</strong>"</p>
                    </div>
                }
            </div>
            <div class="d-flex justify-content-center align-items-center gap-3 mt-5">
                <button class="btn btn-outline-primary shadow-sm"
                        @onclick="PaginaAnterior"
                        disabled="@(currentPage == 1)">
                    <i class="bi bi-chevron-left me-1"></i> Anterior
                </button>

                <span class="fw-bold text-muted">
                    Página <span class="text-primary">@currentPage</span> de @totalPages
                </span>

                <button class="btn btn-outline-primary shadow-sm"
                        @onclick="PaginaSiguiente"
                        disabled="@(currentPage >= totalPages)">
                    Siguiente <i class="bi bi-chevron-right ms-1"></i>
                </button>
            </div>
        }
    </div>
}

@code {

    // --- PROPIEDADES DE DATOS ---
    // Almacena la lista de vehículos cruda que nos devuelve la API.
    private List<VehiculoResponse>? listaDeVehiculo;
    
    // Almacena el texto que el usuario escribe en la barra de búsqueda.
    private string textoBusqueda = "";               

    // Switch booleano para controlar si el usuario tiene permiso de ver la página.
    private bool isAuthorized = false;               

    // --- VARIABLES DE CONTROL DE PAGINACIÓN ---
    private int currentPage = 1;  // Rastrea en qué página está el usuario actualmente.
    private int pageSize = 6;     // Define el límite de tarjetas por pantalla (6 para un diseño limpio).
    private int totalPages = 1;   // Almacenamos el total de páginas calculado por el servidor.
    private int totalCount = 0;   // Cantidad total de coches registrados en la base de datos.

    // --- LÓGICA DE FILTRADO REACTIVO ---
    // Esta lista se recalcula automáticamente cada vez que cambia 'textoBusqueda'.
    // Si el buscador está vacío, devuelve todo. Si no, filtra por marca o modelo.
    private List<VehiculoResponse>? VehiculoFiltrados =>
        string.IsNullOrWhiteSpace(textoBusqueda)
            ? listaDeVehiculo
            : listaDeVehiculo?.Where(v =>
                v.Marca.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                v.Modelo.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
              ).ToList();

    // --- CICLO DE VIDA: AL CARGAR LA PÁGINA ---
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Solo actuamos en el primer renderizado para evitar bucles infinitos.
        if (!firstRender) return;

        // ACCESO AL NAVEGADOR: Recuperamos el token JWT guardado previamente.
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

        if (!string.IsNullOrEmpty(token))
        {

            // Si hay token, autorizamos la vista y disparamos la carga de datos.
            isAuthorized = true;
            await CargarVehiculos(token); 

            // Notificamos a Blazor que el estado ha cambiado para que pinte los coches.
            StateHasChanged();            
        }
        else
        {
            // SEGURIDAD: Si no hay token, el usuario es un intruso. Lo mandamos al Login.
            Navigation.NavigateTo("/login");
        }
    }

    // --- MÉTODO PRINCIPAL: CONSUMO DE API (GET) ---
    private async Task CargarVehiculos(string token)
    {
        try
        {
            // 1. CABECERA DE SEGURIDAD: Inyectamos el Token en la petición HTTP.
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            // 2. PETICIÓN ASÍNCRONA: Llamamos al endpoint pasando los parámetros de paginación por la URL.
            var response = await Http.GetAsync($"api/vehiculos?pageNumber={currentPage}&pageSize={pageSize}");

            if (response.IsSuccessStatusCode)
            {
                // 3. DESERIALIZACIÓN: Traducimos el JSON del servidor a objetos C#.
                // Usamos un 'wrapper' (ApiResponse) que contiene los datos paginados.
                var result = await response.Content
                    .ReadFromJsonAsync<ApiResponse<PagedResult<VehiculoResponse>>>();

                if (result?.Data != null)
                {
                    // 4. MAPEADO DE DATOS: Pasamos la información del paquete a nuestras variables de la UI.
                    listaDeVehiculo = result.Data.Items.ToList();
                    totalCount = result.Data.TotalCount;
                    totalPages = result.Data.TotalPages;
                    currentPage = result.Data.PageNumber;
                }
            }
        }
        catch (Exception ex)
        {
            // MANEJO DE ERRORES: Si la API está caída o el JSON es inválido.
            await JS.InvokeVoidAsync("alert", ex.Message);
        }
    }

    // --- NAVEGACIÓN ---
    // Métodos simples para saltar entre páginas pasando la 'matrícula' como ID.
    private void VerDetalles(string matricula) => Navigation.NavigateTo($"/vehiculo/{matricula}");
    private void EditarVehiculo(string matricula) => Navigation.NavigateTo($"/editar-vehiculo/{matricula}");
    private void IrANuevoVehiculo() => Navigation.NavigateTo("/nuevo-vehiculo");

    // --- MÉTODO DE BORRADO (CRUD - DELETE) ---
    private async Task BorrarVehiculo(string matricula)
    {
        // 1. CONFIRMACIÓN (UX):
        // Usamos JS Interop para lanzar un cuadro de diálogo nativo del navegador.
        // Detenemos la ejecución hasta que el usuario pulse "Aceptar" o "Cancelar".
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Borrar vehículo {matricula}?");
        if (confirmado)
        {
            // 2. SEGURIDAD:
            // Recuperamos el token para demostrarle a la API que tenemos permiso para borrar.
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            // 3. LA PETICIÓN (HTTP DELETE):
            // No usamos 'DeleteAsJson' porque necesitamos añadir el Token en la cabecera (Header).
            // Construimos un mensaje de petición manualmente.
            var request = new HttpRequestMessage(HttpMethod.Delete, $"api/vehiculos/{matricula}");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            
            // Enviamos la petición y esperamos la respuesta del servidor.
            var response = await Http.SendAsync(request);

            // 4. CONTROL DE RESULTADOS:
            if (response.IsSuccessStatusCode) {
                
                // ÉXITO: El coche se borró en la BBDD.
                // Llamamos de nuevo a CargarVehiculos para refrescar la lista y que el coche "desaparezca".
                await CargarVehiculos(token!);
            }
            else 
            {
                // ERROR: Algo falló (ej: el coche tiene alquileres asociados o el token expiró).
                await JS.InvokeVoidAsync("alert", "Error al borrar el vehículo.");
            }
        }
    }

    // --- LÓGICA DE PAGINACIÓN (BOTONES) ---
    private async Task PaginaAnterior()
    {
        if (currentPage > 1)
        {
            currentPage--; // Bajamos el contador de página
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");
            await CargarVehiculos(token); // Pedimos los datos de la página anterior
        }
    }

    private async Task PaginaSiguiente()
    {
        if (currentPage < totalPages)
        {
            currentPage++; // Subimos el contador de página
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");
            await CargarVehiculos(token); // Pedimos los datos de la nueva página
        }
    }
}