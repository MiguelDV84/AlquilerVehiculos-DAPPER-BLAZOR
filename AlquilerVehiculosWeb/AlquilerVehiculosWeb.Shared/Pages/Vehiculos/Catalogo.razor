@page "/catalogo"
@using WebApiNet.Core.Entities
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS


<PageTitle>Nuestra Flota</PageTitle>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text bg-primary text-white">
                <i class="bi bi-search"></i>
            </span>
            <input type="text"
                   class="form-control"
                   placeholder="Escribe marca o modelo (ej: Porsche)..."
                   @bind="textoBusqueda"
                   @bind:event="oninput" />
        </div>
        @if (!string.IsNullOrEmpty(textoBusqueda))
        {
            <div class="form-text text-muted">
                Mostrando resultados para: <strong>@textoBusqueda</strong>
            </div>
        }
    </div>
    <br/>
    <div class="col-md-6">
        <button class="btn btn-success" @onclick="IrANuevoVehiculo">
            <i class="bi bi-plus-circle me-2"></i>Añadir Nuevo Vehículo
        </button>
    </div>
</div>

<div class="container">
    <h1 class="my-4">Catalogo Vehiculos</h1>

    @if (listaDeVehiculos == null)
    {
        <div class="d-flex align-items-center">
            <strong>Cargando flota desde la API...</strong>
            <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
        </div>
    }
    else if (listaDeVehiculos.Count == 0)
    {
        <p>No se encontraron vehículos en la base de datos.</p>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Matrícula</th>
                    <th>Marca</th>
                    <th>Modelo</th>
                    <th>Precio/Día</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (vehiculosFiltrados != null && vehiculosFiltrados.Any())
                {
                    @foreach (var v in vehiculosFiltrados)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@v.Matricula</span></td>
                            <td>@v.Marca</td>
                            <td>@v.Modelo</td>
                            <td>@v.Precio.ToString("C")</td>
                            <td>
                                @if ((int)v.Estado == 0)
                                {
                                    <span class="badge bg-success">Disponible</span>
                                }
                                else if ((int)v.Estado == 1)
                                {
                                    <span class="badge bg-danger">Alquilado</span>
                                }
                                else if ((int)v.Estado == 2)
                                {
                                    <span class="badge bg-danger">En Mantenimiento</span>
                                }
                                else if ((int)v.Estado == 3)
                                {
                                    <span class="badge bg-danger">Vendido</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-info btn-sm text-white" @onclick="() => VerDetalles(v.Matricula)">
                                    <i class="bi bi-eye"></i> Ver Ficha
                                </button>
                                <button class="btn btn-danger btn-sm text-white" @onclick="() => BorrarVehiculo(v.Matricula)">
                                    <i class="bi bi-trash"></i> Borrar Ficha
                                </button>
                            </td>
                        </tr>
                    }
                }
                else if (listaDeVehiculos != null)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">
                            No se encontraron vehículos que coincidan con "<strong>@textoBusqueda</strong>".
                        </td>
                    </tr>
                }
               
            </tbody>
        </table>
    }
</div>

@code {
    // Usamos listaDeVehiculos para evitar conflictos con el nombre de la página
    private List<Vehiculo>? listaDeVehiculos;
    private string textoBusqueda = ""; // Variable para el buscador
    private string mensajePrueba = "Vehículos Disponibles";

    // Esta propiedad se actualiza sola cada vez que escribes
    private List<Vehiculo>? vehiculosFiltrados =>
        string.IsNullOrWhiteSpace(textoBusqueda)
            ? listaDeVehiculos
            : listaDeVehiculos?.Where(v =>
                v.Marca.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                v.Modelo.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
              ).ToList();

    private void VerDetalles(string matricula)
    {
        Navigation.NavigateTo($"/vehiculo/{matricula}");
    }

    private void IrANuevoVehiculo()
    {
        Navigation.NavigateTo("/nuevo-vehiculo");
    }

    private async Task BorrarVehiculo(string matricula)
    {
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Estás seguro de que quieres borrar el vehículo con matrícula {matricula}? Esta acción no se puede deshacer.");
        if (confirmado)
        {
            var response = await Http.DeleteAsync($"api/v2/vehiculos/{matricula}");
            if (response.IsSuccessStatusCode)
            {
                // Refrescamos la lista después de borrar
                listaDeVehiculos = await Http.GetFromJsonAsync<List<Vehiculo>>("api/v2/vehiculos");
            }
            else
            {
                Console.WriteLine($"Error al borrar el vehículo: {response.ReasonPhrase}");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            listaDeVehiculos = await Http.GetFromJsonAsync<List<Vehiculo>>("api/v2/vehiculos");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al conectar con la API: {ex.Message}");
        }
    }
}