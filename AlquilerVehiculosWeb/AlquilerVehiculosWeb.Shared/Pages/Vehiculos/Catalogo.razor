@page "/catalogo"
@rendermode InteractiveServer
@using AlquilerVehiculosWeb.Shared
@using WebApiNet.Shared.DTOs.Common
@using WebApiNet.Shared.DTOs.Vehiculo
@using WebApiNet.Shared.Enums
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Gestión de Catálogo</PageTitle>
@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p>Verificando autorización...</p>
    </div>
}
else if (listaDeVehiculo != null)
{
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text bg-primary text-white">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text"
                       class="form-control"
                       placeholder="Escribe marca o modelo (ej: Porsche)..."
                       @bind="textoBusqueda"
                       @bind:event="oninput" />
            </div>
            @if (!string.IsNullOrEmpty(textoBusqueda))
            {
                <div class="form-text text-muted">
                    Mostrando resultados para: <strong>@textoBusqueda</strong>
                </div>
            }
        </div>
        <br />
        <div class="col-md-6">
            <button class="btn btn-success" @onclick="IrANuevoVehiculo">
                <i class="bi bi-plus-circle me-2"></i>Añadir Nuevo Vehículo
            </button>
        </div>
    </div>

    <div class="container">
        <h1 class="my-4">Catalogo Vehiculo</h1>

        @if (listaDeVehiculo == null)
        {
            <div class="d-flex align-items-center">
                <strong>Cargando flota desde la API...</strong>
                <div class="spinner-border ms-auto" role="status" aria-hidden="true"></div>
            </div>
        }
        else if (listaDeVehiculo.Count == 0)
        {
            <p>No se encontraron vehículos en la base de datos.</p>
        }
        else
        {
            <table class="table table-striped table-hover shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Matrícula</th>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>Precio/Día</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (VehiculoFiltrados != null && VehiculoFiltrados.Any())
                    {
                        @foreach (var v in VehiculoFiltrados)
                        {
                            <tr>
                                <td><span class="badge bg-secondary">@v.Matricula</span></td>
                                <td>@v.Marca</td>
                                <td>@v.Modelo</td>
                                <td>@v.Precio.ToString("C")</td>
                                <td>
                                    @if ((int)v.Estado == 0)
                                    {
                                        <span class="badge bg-success">Disponible</span>
                                    }
                                    else if ((int)v.Estado == 1)
                                    {
                                        <span class="badge bg-danger">Alquilado</span>
                                    }
                                    else if ((int)v.Estado == 2)
                                    {
                                        <span class="badge bg-danger">En Mantenimiento</span>
                                    }
                                    else if ((int)v.Estado == 3)
                                    {
                                        <span class="badge bg-danger">Vendido</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-info btn-sm text-white" @onclick="() => VerDetalles(v.Matricula)">
                                        <i class="bi bi-eye"></i> Ver Ficha
                                    </button>

                                    <button class="btn btn-warning btn-sm text-white" @onclick="() => EditarVehiculo(v.Matricula)">
                                        <i class="bi bi-pencil"></i> Editar Ficha
                                    </button>

                                    <button class="btn btn-danger btn-sm text-white" @onclick="() => BorrarVehiculo(v.Matricula)">
                                        <i class="bi bi-trash"></i> Borrar Ficha
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else if (listaDeVehiculo != null)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                No se encontraron vehículos que coincidan con "<strong>@textoBusqueda</strong>".
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        }
    </div>
}


@code {
    // Usamos listaDeVehiculo para evitar conflictos con el nombre de la página
    private List<VehiculoResponse>? listaDeVehiculo;
    private string textoBusqueda = ""; // Variable para el buscador
    Boolean isAuthorized = false;

    // Esta propiedad se actualiza sola cada vez que escribes
    private List<VehiculoResponse>? VehiculoFiltrados =>
        string.IsNullOrWhiteSpace(textoBusqueda)
            ? listaDeVehiculo
            : listaDeVehiculo?.Where(v =>
                v.Marca.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase) ||
                v.Modelo.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)
              ).ToList();

    private void VerDetalles(string matricula)
    {
        Navigation.NavigateTo($"/vehiculo/{matricula}");
    }

    private void EditarVehiculo(string matricula)
    {
        Navigation.NavigateTo($"/editar-vehiculo/{matricula}");
    }

    private void IrANuevoVehiculo()
    {
        Navigation.NavigateTo("/nuevo-vehiculo");
    }

    private async Task BorrarVehiculo(string matricula)
    {
        // 1. Pedimos confirmación al usuario
        bool confirmado = await JS.InvokeAsync<bool>("confirm", $"¿Estás seguro de que quieres borrar el vehículo con matrícula {matricula}?");

        if (confirmado)
        {
            try
            {
                // 1. Intentamos recuperar el token del navegador
                var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

                // 2. CONFIGURAR LA LLAMADA DELETE CON TOKEN
                var requestDelete = new HttpRequestMessage(HttpMethod.Delete, $"api/vehiculos/{matricula}");
                requestDelete.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                var responseDelete = await Http.SendAsync(requestDelete);

                if (responseDelete.IsSuccessStatusCode)
                {
                    // 3. SI EL BORRADO FUE EXITOSO, REFRESCAMOS LA LISTA (También con Token)
                    var requestRefresh = new HttpRequestMessage(HttpMethod.Get, "api/vehiculos");
                    requestRefresh.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

                    var responseRefresh = await Http.SendAsync(requestRefresh);

                    if (responseRefresh.IsSuccessStatusCode)
                    {
                        var refresh = await responseRefresh.Content.ReadFromJsonAsync<ApiResponse<List<VehiculoResponse>>>();
                        if (refresh != null && refresh.Success)
                        {
                            listaDeVehiculo = refresh.Data;
                        }
                    }
                }
                else if (responseDelete.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    await JS.InvokeVoidAsync("alert", "Tu sesión ha expirado. Identifícate de nuevo.");
                    Navigation.NavigateTo("/login");
                }
                else
                {
                    await JS.InvokeVoidAsync("alert", "No se pudo eliminar el vehículo. Verifica si tiene alquileres asociados.");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error al borrar: {ex.Message}");
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Solo ejecutamos la lógica la primera vez que se renderiza
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            if (string.IsNullOrEmpty(token))
            {
                Navigation.NavigateTo("/login");
            }
            else
            {
                isAuthorized = true; // El usuario puede ver la página
                await CargarVehiculos(token);
                StateHasChanged(); // Forzamos a Blazor a redibujar con los datos
            }
        }
    }

    private async Task CargarVehiculos(string token)
    {
        try
        {
            var request = new HttpRequestMessage(HttpMethod.Get, "api/vehiculos");
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<List<VehiculoResponse>>>();
                if (result != null && result.Success)
                {
                    listaDeVehiculo = result.Data;
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error crítico: {ex.Message}");
        }
    }
}