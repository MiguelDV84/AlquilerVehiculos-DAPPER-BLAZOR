@page "/"
@using AlquilerVehiculosWeb.Shared.Services
@inject IFormFactor FormFactor

<PageTitle>Inicio - Alquiler</PageTitle>

<h1>Gestión de Alquiler de Vehículos</h1>

<div class="alert alert-info">
    Bienvenido al sistema. Estás conectado desde: <strong>@plataforma</strong>
</div>

<div class="mt-4">
    <label>Buscar vehículo por modelo:</label>
    <input type="text" @bind="busqueda" @bind:event="oninput" class="form-control" placeholder="Ej: Toyota..." />

    <p class="mt-2">
        Filtrando por: <strong>@busqueda</strong>
    </p>
</div>

@code {
    private string? plataforma;
    private string busqueda = "";

    // Unificamos aquí todas las propiedades y lógica
    private string factor => FormFactor.GetFormFactor();

    protected override void OnInitialized()
    {
        plataforma = FormFactor.GetPlatform();
    }
}