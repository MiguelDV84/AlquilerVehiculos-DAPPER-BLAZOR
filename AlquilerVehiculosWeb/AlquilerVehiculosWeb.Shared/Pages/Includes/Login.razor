@page "/login"
@using WebApiNet.Shared.DTOs.Auth
@using WebApiNet.Shared.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS


<div>
    <div class="row justify-content-center">
        <div class="col-md-4 mt-5">
            <div class="card shadow">
                <div class="card-header">
                    <h3>Iniciar Sesion</h3>
                </div>
                <div class="card-body">
                    <EditForm Model="loginModel" OnValidSubmit="RealizarLogin">
                        <DataAnnotationsValidator />

                        <div>
                            <label for="email">Correo Electronico</label>
                            <InputText id="email" class="form-control" @bind-Value="loginModel.Email" />
                            <ValidationMessage For="@(() => loginModel.Email)" class="text-danger" />
                        </div>

                        <div>
                            <label for="password">Contraseña</label>
                            <InputText type="password" id="password" class="form-control" @bind-Value="loginModel.Password" />
                            <ValidationMessage For="@(() => loginModel.Password)" class="text-danger" />
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100" disabled="@isProcessing">
                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span> Cargando...</span>
                            }
                            else
                            {
                                <i class="bi bi-box-arrow-in-right"></i><span> Acceder</span>
                            }
                        </button>
                        
                    </EditForm>
                </div>
                <div class="card-footer" >
                    <p>¿No tienes una cuenta? <a href="/register">Registrate aquí</a></p>
                </div>  
            </div>
        </div>
    </div>
</div>

@code {
    // --- MODELO DE DATOS ---
    // Objeto que vincula el Email y Password del formulario con C#.
    private LoginRequest loginModel = new();

    // Variable de estado para controlar visualmente el botón de acceso.
    private Boolean isProcessing = false;

    // --- PROCESO DE AUTENTICACIÓN ---
    private async Task RealizarLogin()
    {
        isProcessing = true; // Desactivamos el botón y mostramos el spinner.
        try
        {
            // 1. PETICIÓN AL SERVIDOR: Enviamos las credenciales a la API.
            // Usamos POST porque estamos enviando información sensible.
            var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                // 2. RECEPCIÓN DEL TOKEN: Si las credenciales son válidas, la API responde con un JSON
                // que contiene el Token JWT y los datos del usuario.
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<AuthResponse>>();

                if (result != null && result.Success)
                {
                    // 3. PERSISTENCIA (LOCAL STORAGE):
                    // Guardamos el Token en el navegador para que el usuario no tenga que
                    // loguearse cada vez que refresque la página o cambie de sección.
                    await JS.InvokeVoidAsync("localStorage.setItem", "token", result.Data.Token);
                    await JS.InvokeVoidAsync("localStorage.setItem", "usuarioNombre", result.Data.User.Nombre);

                    // 4. REDIRECCIÓN: Vamos a la página principal.
                    // Usamos 'forceLoad: true' para que la App se recargue y reconozca el nuevo estado de login.
                    Navigation.NavigateTo("/", forceLoad: true);
                }
            }
            else
            {
                // Manejo de errores (Credenciales incorrectas o usuario no encontrado).
                await JS.InvokeVoidAsync("alert", "Error al iniciar sesión. Verifica tus credenciales.");
            }
        }
        catch (Exception ex)
        {
            // Error de conexión o fallo inesperado del servidor.
            await JS.InvokeVoidAsync("alert", $"Ocurrió un error: {ex.Message}");
        }
        finally
        {
            isProcessing = false; // Reactivamos el botón independientemente del resultado.
        }
    }
}