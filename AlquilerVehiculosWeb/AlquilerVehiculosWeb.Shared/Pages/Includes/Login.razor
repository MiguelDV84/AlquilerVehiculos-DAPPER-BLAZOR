@page "/login"
@using WebApiNet.Shared.DTOs.Auth
@using WebApiNet.Shared.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS


<div>
    <div class="row justify-content-center">
        <div class="col-md-4 mt-5">
            <div class="card shadow">
                <div class="card-header">
                    <h3>Iniciar Sesion</h3>
                </div>
                <div class="card-body">
                    <EditForm Model="loginModel" OnValidSubmit="RealizarLogin">
                        <DataAnnotationsValidator />

                        <div>
                            <label for="email">Correo Electronico</label>
                            <InputText id="email" class="form-control" @bind-Value="loginModel.Email" />
                            <ValidationMessage For="@(() => loginModel.Email)" class="text-danger" />
                        </div>

                        <div>
                            <label for="password">Contraseña</label>
                            <InputText type="password" id="password" class="form-control" @bind-Value="loginModel.Password" />
                            <ValidationMessage For="@(() => loginModel.Password)" class="text-danger" />
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">

                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span> Cargando...</span>
                            }
                            else
                            {
                                <i class="bi bi-person-plus"></i><span> Registrar</span>
                            }

                        </button>
                        
                    </EditForm>
                </div>
                <div class="card-footer" >
                    <p>¿No tienes una cuenta? <a href="/register">Registrate aquí</a></p>
                </div>  
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest loginModel = new();

    private Boolean isProcessing = false;

    private async Task RealizarLogin()
    {
        isProcessing = true;

        var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ApiResponse<AuthResponse>>();
            if (result != null && result.Success)
            {
                // Guardamos los datos en el navegador para que el Frontend los recuerde
                await JS.InvokeVoidAsync("localStorage.setItem", "token", result.Data.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "usuarioNombre", result.Data.User.Nombre);
                
                // Redirigir al usuario a la página principal o dashboard
                Navigation.NavigateTo("/", forceLoad: true);
            }
        }
        else
        {
            // Manejar error de inicio de sesión
            await JS.InvokeVoidAsync("alert", "Error al iniciar sesión. Por favor, verifica tus credenciales.");
        }
    }
}
