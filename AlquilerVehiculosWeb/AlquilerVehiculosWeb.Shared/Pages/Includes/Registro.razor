@page "/register"
@using WebApiNet.Shared.DTOs.Auth
@using WebApiNet.Shared.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div>
    <div class="row justify-content-center">
        <div>
            <div class="card-header">
                <h3>Crear Cuenta</h3>
            </div>
            <div class="card-body">
                <EditForm Model="registrarRequest" OnValidSubmit="CrearUsuario">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label for="dni">DNI: </label>
                        <InputText id="dni" class="form-control" @bind-Value="registrarRequest.Dni" />
                        <ValidationMessage For="@(() => registrarRequest.Dni)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label for="nombre">Nombre: </label>
                        <InputText id="nombre" class="form-control" @bind-Value="registrarRequest.Nombre" />
                        <ValidationMessage For="@(() => registrarRequest.Nombre)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label for="email">Email: </label>
                        <InputText id="email" class="form-control" @bind-Value="registrarRequest.Email" />
                        <ValidationMessage For="@(() => registrarRequest.Email)" class="text-danger" />
                    </div>

                    <div class="mb-3">
                        <label for="password">Password: </label>
                        <InputText type="password" id="password" @bind-Value="registrarRequest.Password" class="form-control" />
                        <ValidationMessage For="@(() => registrarRequest.Password)" class="text-danger" />
                    </div> 

                    <div class="d-flex gap-2 justify-content-end">
                        
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">
                            <i class="bi bi-x-circle"></i> Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary" disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                <span> Registrando...</span>
                            }
                            else
                            {
                                <i class="bi bi-person-plus"></i>
                            
                                <span> Registrar</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
            <div class="card-footer">
                <p>¿Ya tienes una cuenta? <a href="/login">Iniciar sesión aquí</a></p>
            </div>
        </div>
    </div>
</div>
