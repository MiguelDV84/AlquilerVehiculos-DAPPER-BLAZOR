@page "/perfil"
@using WebApiNet.Shared.DTOs.Auth
@using WebApiNet.Shared.DTOs.Common
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                @* CABECERA DECORATIVA *@
                <div class="profile-header">
                    <div class="text-center pt-4">
                        <div class="avatar-circle shadow">
                            <i class="bi bi-person-fill text-white"></i>
                        </div>
                        <h4 class="text-white mt-3 mb-0 fw-bold">@userResponse?.Nombre</h4>
                        <p class="text-white-50 small">Cliente VIP RentDrive</p>
                    </div>
                </div>

                <div class="card-body p-4">
                    @if (userResponse == null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-3 text-muted">Sincronizando con la central...</p>
                        </div>
                    }
                    else
                    {
                        <div class="profile-info-grid">
                            @* DNI *@
                            <div class="info-item d-flex align-items-center mb-4">
                                <div class="icon-box me-3">
                                    <i class="bi bi-card-text text-primary"></i>
                                </div>
                                <div>
                                    <label class="text-muted small d-block">Identificación (DNI)</label>
                                    <span class="fw-bold fs-5">@userResponse.Dni</span>
                                </div>
                            </div>

                            @* EMAIL *@
                            <div class="info-item d-flex align-items-center mb-4">
                                <div class="icon-box me-3">
                                    <i class="bi bi-envelope-at text-primary"></i>
                                </div>
                                <div>
                                    <label class="text-muted small d-block">Correo Electrónico</label>
                                    <span class="fw-bold fs-5">@userResponse.Email</span>
                                </div>
                            </div>

                            @* ESTADO DE CUENTA (Extra visual) *@
                            <div class="info-item d-flex align-items-center mb-4">
                                <div class="icon-box me-3">
                                    <i class="bi bi-shield-check text-success"></i>
                                </div>
                                <div>
                                    <label class="text-muted small d-block">Estado de Cuenta</label>
                                    <span class="badge bg-success-subtle text-success rounded-pill">Verificada</span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button class="btn btn-dark btn-lg rounded-3 shadow-sm" @onclick="Volver">
                                <i class="bi bi-arrow-left me-2"></i>Volver al Catálogo
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

