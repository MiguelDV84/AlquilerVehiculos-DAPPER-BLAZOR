@page "/alquiler"
@rendermode InteractiveServer
@using AlquilerVehiculosWeb.Shared
@using WebApiNet.Shared.DTOs.Alquiler
@using WebApiNet.Shared.Enums
@using WebApiNet.Shared.Paged
@using WebApiNet.Shared.DTOs.Common
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS


@if (!isAuthorized)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Verificando autorización...</p>
    </div>
}
else
{
    <div class="container py-4">
        <h2 class="mb-4 text-primary"><i class="bi bi- calendar-range"></i> Gestión de Alquileres</h2>

        @if (Listadoalquileres == null)
        {
            <div class="text-center my-5">
                <div class="spinner-grow text-primary" role="status"></div>
                <p class="mt-3 text-muted">Cargando datos desde la API...</p>
            </div>
        }
        else if (Listadoalquileres.Count == 0)
        {
            <div class="alert alert-info text-center rounded-3 shadow-sm">
                <i class="bi bi-info-circle me-2"></i> No hay alquileres registrados en el sistema.
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var alquiler in Listadoalquileres)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0">
                            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                                <span class="fw-bold"><i class="bi bi-car-front"></i> @alquiler.VehiculoMatricula</span>
                                <span class="badge bg-success">@alquiler.Precio.ToString("N2") €</span>
                            </div>
                            <div class="card-body">
                                <p class="card-text"><strong><i class="bi bi-person-vcard"></i> Cliente:</strong> @alquiler.ClienteDni</p>
                                <p class="card-text"><strong><i class="bi bi-calendar-check"></i> Inicio:</strong> @alquiler.FechaAlquiler</p>
                                <p class="card-text"><strong><i class="bi bi-calendar-event"></i> Prevista:</strong> @alquiler.FechaDevolucionPrevista</p>

                                @if (alquiler.FechaDevolucionReal.HasValue)
                                {
                                    <p class="card-text text-success">
                                        <strong><i class="bi bi-check-all"></i> Finalizado:</strong> @alquiler.FechaDevolucionReal.Value
                                    </p>
                                }
                                else
                                {
                                    <p class="card-text text-warning">
                                        <strong><i class="bi bi-clock-history"></i> Estado:</strong> Activo
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}


@code {
    // Lista de alquileres que se mostrarán en la página.
    private List<AlquilerResponse>? Listadoalquileres;

    // Switch booleano para controlar si el usuario tiene permiso de ver la página.
    Boolean isAuthorized = false;

    // --- CICLO DE VIDA: AL CARGAR LA PÁGINA ---
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var MiToken = await JS.InvokeAsync<string>("localStorage.getItem", "token");

            if(!string.IsNullOrEmpty(MiToken))
            {
                isAuthorized = true;
                // Si hay token, autorizamos la vista y disparamos la carga de datos.
                isAuthorized = true;
                await CargarAlquileres(MiToken);

                // Notificamos a Blazor que el estado ha cambiado para que pinte los coches.
                StateHasChanged();
            }
            else
            {
                // Si no hay token, redirigimos al login.
                Navigation.NavigateTo("/login");
            }
        }
    }

    private async Task CargarAlquileres(String Token)
    {
        try
        {
            // Configuramos el HttpClient para incluir el token en la cabecera de autorización.
            Http.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", Token);

            // Hacemos la petición GET a la API para obtener los alquileres.
            var result = await Http.GetFromJsonAsync<ApiResponse<List<AlquilerResponse>>>("api/alquiler");
            if (result != null && result.Success)
            {
                // Si la respuesta es exitosa, asignamos los datos a la variable que se muestra en la UI.
                Listadoalquileres = result.Data;
            }
            else
            {
                // Si la respuesta no es exitosa, mostramos una alerta con el mensaje de error.
                await JS.InvokeVoidAsync("alert", $"Error al cargar alquileres: {result?.Message ?? "Respuesta vacía"}");
            }
        }
        catch (Exception ex)
        {
            // En caso de error, mostramos una alerta y redirigimos al login (posible token expirado).
            await JS.InvokeVoidAsync("alert", $"Error al cargar alquileres: {ex.Message}");
            Navigation.NavigateTo("/");
        }
    }

}
